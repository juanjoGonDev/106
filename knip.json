{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "public/privacy-bootstrap.js",
    "public/app.js",
    "public/access.js",
    "public/account.js",
    "public/attempt-refresh.js",
    "public/compliance.js",
    "public/competition.js",
    "public/format.js",
    "public/human-check-ready-flow.js",
    "public/human-check.js",
    "public/honours.js",
    "public/share-actions.js",
    "public/layout.js",
    "public/player-stats.js",
    "public/player-ui.js",
    "public/player.js",
    "public/profile-enhancements.js",
    "public/ranking-enhancements.js",
    "public/ranking.js",
    "public/ligas.js",
    "public/stop-control.js",
    "public/v3.js",
    "public/v4.js",
    "scripts/*.mjs",
    "tests/**/*.test.js",
    "tests/**/*.node-test.js",
    "tests/e2e/**/*.e2e.js",
    "playwright.config.js"
  ],
  "project": [
    "public/**/*.js",
    "scripts/**/*.mjs",
    "tests/**/*.js",
    "playwright.config.js"
  ],
  "ignore": [
    "public/config.js",
    "supabase/functions/**/*.ts"
  ],
  "ignoreBinaries": [
    "supabase"
  ],
  "ignoreDependencies": [
    "@playwright/test"
  ]
}